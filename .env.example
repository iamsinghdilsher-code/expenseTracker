# Copy this file to .env and fill in values for local development.
# Never commit .env to git.

# Required in production — any long random string (e.g. `openssl rand -hex 32`)
SECRET_KEY=dev-secret-change-in-prod

# Set to "production" when deploying; omit or leave blank for local dev
FLASK_ENV=

# Path to the SQLite database file
# Production: point this at a persistent volume (e.g. /data/expense_tracker.db)
# DATABASE_PATH=/data/expense_tracker.db

# Path where uploaded receipts/CSVs are stored
# Production: point this at a persistent volume (e.g. /data/uploads)
# UPLOAD_FOLDER=/data/uploads

# Enables LLM receipt parsing and batch categorisation (claude-haiku)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Secures the Postmark inbound email webhook — any random string
WEBHOOK_SECRET=
